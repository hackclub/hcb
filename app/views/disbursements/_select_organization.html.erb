<%# locals: (form:, field_name:, label:, disabled:, sending: false, source_event: nil) %>

<% search_path = if sending
                   event_search_disbursements_path(sending: true)
                 elsif source_event
                   event_search_disbursements_path(source_event_id: source_event.id)
                 else
                   event_search_disbursements_path
                 end %>

<div class="field flex-1">
  <%= form.label field_name, label %>
  <%= form.combobox field_name.to_sym, search_path, placeholder: "Select one...", disabled: disabled, class: "!max-w-full" %>
</div>
