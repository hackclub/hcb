<%# locals: (form:, field_name:, label:, disabled:, default_event:, sending: false, source_event: nil) %>

<% search_path = if sending
                   event_search_disbursements_path(sending: true)
                 elsif source_event
                   event_search_disbursements_path(source_event_id: source_event.id)
                 else
                   event_search_disbursements_path
                 end %>

<div class="field flex-1">
  <%= form.label field_name, label %>
  <% prefilled_display = admin_signed_in? ? default_event&.to_combobox_display : default_event&.name %>
  <%= combobox_tag "disbursement[#{field_name}]", search_path, placeholder: "Select one...", disabled: disabled, value: default_event&.public_id, class: "!max-w-full", data: { hw_combobox_prefilled_display_value: prefilled_display } %>
</div>
