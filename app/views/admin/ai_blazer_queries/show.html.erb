<% title @query.name %>

<div class="max-w-5xl mx-auto flex flex-col gap-3">
  <div class="flex flex-col sm:flex-row sm:items-center gap-2">
    <%= link_to admin_ai_blazer_queries_path, class: "btn btn-small bg-muted" do %>
      <%= inline_icon "view-back" %>
      Back
    <% end %>

    <div class="ml-auto flex gap-2">
      <%= link_to "Open in Blazer", "/blazer/queries/#{@query.id}", class: "btn bg-accent", target: "_blank", rel: "noopener" %>
    </div>
  </div>

  <div class="card p3">
    <h1 class="mt0 mb1"><%= @query.name %></h1>
    <p class="mb0 muted">
      Created by <%= @query.creator&.full_name || "Unknown" %>
      · <%= local_time(@query.created_at) %>
      · Updated <%= local_time_ago(@query.updated_at) %>
    </p>
  </div>

  <div class="card p3">
    <h2 class="mt0 mb2">Prompt</h2>
    <p class="mb0 whitespace-pre-wrap"><%= @prompt.presence || "Prompt not found in SQL comment." %></p>
  </div>

  <div class="card p3">
    <h2 class="mt0 mb2">Generated SQL</h2>
    <pre class="bg-snow p2 mb0 overflow-x-auto"><code><%= @statement %></code></pre>
  </div>
</div>
