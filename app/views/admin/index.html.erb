      <% admin_cards.each_value do |section| %>
        <h2 class="mt-5 first:mt-0 p-0"><%= section[:title] %></h2>
        <ul class="grid text-left p-0 w-100 mt0 gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4" id="<%= section[:grid_id] %>">
          <% section[:cards].each do |card| %>
            <%= link_to card[:link], class: "link-reset" do %>
              <li class="card card--hover flex items-center gap-3 py-2 m-0">
                <%= inline_icon(card[:icon].presence || "bank-account", size: 28, class: "muted shrink-0") %>
                <span class="flex flex-col min-w-0 leading-tight">
                  <strong class="truncate">
                    <%= card[:name] %>
                    <% if "airtable".in? card[:link] %>
                      <%= inline_icon("airtable", size: 14, class: "ml-1 muted shrink-0") %>
                    <% end %>
                  </strong>
                  <% if card[:async_badge].present? %>
                    <%= turbo_frame_tag card[:async_badge], src: admin_task_size_path(task_name: card[:async_badge], style: :plain), class: "admin-card-count muted" do %>
                      ...
                    <% end %>
                  <% else %>
                    <% count_value = card[:badge] %>
                    <% count_class = card[:subtle_badge].present? || count_value.to_i == 0 ? "muted" : "accent" %>
                    <span class="admin-card-count <%= count_class %>"><%= count_value.present? || count_value == 0 ? number_with_delimiter(count_value) : "—" %></span>
                  <% end %>
                </span>
              </li>
            <% end %>
          <% end %>
        </ul>
      <% end %>
