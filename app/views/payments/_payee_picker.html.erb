<%# locals: (event:) %>
<% manual = params[:manual] == "true" %>

<div>
  <div data-payee-picker-target="defaultPanel" class="py-2">
    <% if event.payees.any? %>
      <%= turbo_frame_tag :payee_results, src: event_payees_path(event_id: event.slug, payee_id: params[:payee_id]) %>
    <% end %>

    <a class="btn btn--list-item <%= "border-t" if event.payees.any? %> rounded-none w-full" data-action="payee-picker#showAdding" data-payee-picker-target="searchHidden">
      <div class="w-10 h-10 shrink-0 rounded-full border-2 border-current flex items-center justify-center muted">
        <%= inline_icon "plus", size: 18 %>
      </div>
      <div class="text-left">
        <p class="font-medium">New recipient</p>
        <p class="text-sm muted">Create a new payment recipient</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    </a>
  </div>

  <div data-payee-picker-target="addingPanel" hidden>
    <div class="px-4 py-3">
      <button type="button" class="btn mb-3" data-action="payee-picker#hideAdding">
        <%= inline_icon "view-back" %>
        Back
      </button>

      <%# The recipient's name/email live in this contractor form but are also
          associated (via form:) so they submit here on the contractor path. On the
          manual path they're mirrored into the payment form by manual-payee. %>
      <%= form_with(url: event_payees_path(event_id: event.slug), local: true, id: "new-payee-form", html: { class: "contents" }) do %>
      <% end %>

      <div class="flex flex-col gap-3" data-manual-payee-target="editPanel">
        <div class="flex justify-between flex-col sm:flex-row items-center gap-2">
          <%= label_tag :name, "Name" %>
          <%= text_field_tag :name, params[:payee_name], placeholder: "Orpheus", required: true, form: "new-payee-form", data: { action: "input->manual-payee#sync", "manual-payee-target": "nameInput" } %>
        </div>
        <div class="flex justify-between flex-col sm:flex-row items-center gap-2">
          <%= label_tag :email, "Email" %>
          <%= email_field_tag :email, params[:payee_email], placeholder: "orpheus@hackclub.com", required: true, form: "new-payee-form", data: { action: "input->manual-payee#sync", "manual-payee-target": "emailInput" } %>
        </div>
        <div class="flex justify-between flex-col sm:flex-row items-center gap-2" data-manual-payee-target="manualOnly" <%= "hidden" unless manual %>>
          <%= label_tag :payee_entity_type, "Recipient type" %>
          <%= select_tag :payee_entity_type,
              options_for_select([
                                   ["Select whether they're an individual or a business", ""],
                                   ["An individual", "person"],
                                   ["A business or organization", "business"]
                                 ], params[:payee_entity_type]),
              required: true,
              data: { action: "change->manual-payee#sync", "manual-payee-target": "entityTypeInput" } %>
        </div>

        <div data-manual-payee-target="defaultBanner" <%= "hidden" if manual %>>
          <%= render "application/callout", type: "info", title: "HCB will email the recipient", class: "mt-0 mb-0" do %>
            They'll be asked to submit their tax information and configure their payout method before receiving the payment.
          <% end %>
        </div>

        <div data-manual-payee-target="manualBanner" <%= "hidden" unless manual %>>
          <%= render "application/callout", type: "warning", icon: "important", title: "Manual entry selected", class: "mt-0 mb-0" do %>
            You'll need to provide payout details and tax info below. Only use this if the recipient can't submit their own.
          <% end %>
        </div>
 
          <button type="button" class="btn bg-blue w-full gap-2 mt-3" data-action="manual-payee#continue">
            Continue <%= inline_icon "view-forward" %>
          </button>
          <button type="button" class="btn bg-smoke dark:bg-darkless w-full text-sm font-[500] mt-1" data-manual-payee-target="enableButton" data-action="manual-payee#enable" <%= "hidden" if manual %>>
            I want to submit tax and payout information on behalf of the recipient
          </button>
          <button type="button" class="btn bg-smoke dark:bg-darkless w-full text-sm mt-1" data-manual-payee-target="undoButton" data-action="manual-payee#undo" <%= "hidden" unless manual %>>
            I'll have the recipient fill this out instead
          </button>
        </div>

        <div class="flex items-center justify-between gap-2 py-2" data-manual-payee-target="summaryPanel" hidden>
          <div class="min-w-0">
            <p class="font-medium m-0 truncate" data-manual-payee-target="summaryName"></p>
            <p class="text-sm muted m-0 truncate" data-manual-payee-target="summaryEmail"></p>
          </div>
          <a class="muted text-sm cursor-pointer shrink-0" data-action="manual-payee#edit">Edit</a>
        </div>
      </div>
    </div>
  </div>
</div>
