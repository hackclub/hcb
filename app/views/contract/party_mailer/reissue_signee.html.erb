<p>Hi there! 👋</p>

<% if @message.present? %>
  <p>
    We have reviewed the agreement you signed for <%= @contract.event_name %>.
    However, we cannot finalize this agreement due to an issue in your submission:
  </p>
  <blockquote><%== MarkdownService.instance.renderer.render @message %></blockquote>
<% else %>
  <p>
    We have reviewed the agreement you signed for <%= @contract.event_name %>.
    However, we cannot finalize this agreement due to an issue in your parent or legal guardian's submission.
  </p>
<% end %>

<p><%= link_to "Click here", contract_party_url(@party) %> to sign a new agreement<%= " addressing the above issue" if @message.present? %>.</p>

<p>
  Best,<br>
  The <%= link_to "HCB", "https://hackclub.com/hcb?utm_source=hcb&utm_medium=email" %> Team
</p>
