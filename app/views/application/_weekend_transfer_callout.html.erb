<% unless Date.today.workday? %>
  <%= render "application/callout", type: "warning", title: "HCB team is out of office", class: "mt-2 mb-0" do %>
    It is currently the weekend and the HCB team is out of office. Transfers will be reviewed on the <span class="tooltipped" aria-label="<%= Date.today.next_business_day.strftime("%b %e, %Y") %>">next business day</span>.
  <% end %>
<% end %>
