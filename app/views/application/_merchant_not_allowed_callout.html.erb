<% if hcb_codes.first&.canonical_pending_transactions&.any? { |pt| pt.hcb_decline_reason == :merchant_not_allowed } %>
  <% event_name = hcb_codes.first.event&.name || "this card" %>
  <%= render "application/callout", type: "warning", title: "Transaction declined for #{event_name}" do %>
    One or more transactions were declined because the merchant isn't enabled for this card. Please reach out to the <%= event_name %> team if you need support.
  <% end %>
<% end %>
