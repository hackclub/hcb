<%# locals: (card_grant:) %>

<% if card_grant.pending_invite? %>
  <div class="flex flex-col sm:flex-row gap-4 w-full max-w-2xl mx-auto">
    <div class="card border b--info flex-1 flex flex-col items-center text-center gap-3">
      <%= inline_icon "card", size: 32, class: "text-info" %>
      <div>
        <div class="flex items-center justify-center gap-2 mb-1">
          <h3 class="m-0">Virtual card</h3>
          <span class="badge bg-info">Recommended</span>
        </div>
        <p class="m-0 text-sm opacity-70">Spend online or in-person with digital wallets.</p>
      </div>
      <%= form_with url: activate_card_grant_path(card_grant) do |form| %>
        <div class="field field--checkbox justify-center">
          <%= form.check_box :terms, required: true %>
          <%= form.label :terms do %>
            I agree to the <%= link_to "Card Issuing Terms", "https://stripe.com/legal/issuing/celtic-authorized-user-terms" %>
          <% end %>
        </div>
        <div class="actions">
          <%= form.submit "Get a virtual card" %>
        </div>
      <% end %>
    </div>

    <div class="flex items-center justify-center text-sm opacity-50 font-bold sm:flex-col">
      <span>or</span>
    </div>

    <div class="card border flex-1 flex flex-col items-center text-center gap-3">
      <%= inline_icon "bank-account", size: 32 %>
      <div>
        <h3 class="m-0 mb-1">Bank reimbursement</h3>
        <p class="m-0 text-sm opacity-70">Can't use a virtual card? Reimburse yourself up to <%= render_money card_grant.amount %> with a bank account in a supported country.</p>
      </div>
      <%= form_with url: convert_to_reimbursement_report_event_card_grant_path(card_grant) do |form| %>
        <div class="actions">
          <%= form.submit "Open a reimbursement" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
