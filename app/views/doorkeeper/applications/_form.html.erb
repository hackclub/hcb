<%= form_for application, url: doorkeeper_submit_path(application), as: :doorkeeper_application, html: { role: 'form' } do |f| %>
  <% if application.errors.any? %>
    <div class="alert alert-danger" data-alert><p><%= t('doorkeeper.applications.form.error') %></p></div>
  <% end %>

  <div class="form-group row">
    <%= f.label :name, class: 'col-sm-2 col-form-label font-weight-bold' %>
    <div class="col-sm-10">
      <%= f.text_field :name, class: "form-control #{ 'is-invalid' if application.errors[:name].present? }", required: true %>
      <%= doorkeeper_errors_for application, :name %>
    </div>
  </div>

  <div class="form-group row">
    <%= f.label :redirect_uri, class: 'col-sm-2 col-form-label font-weight-bold' %>
    <div class="col-sm-10">
      <%= f.text_area :redirect_uri, class: "form-control #{ 'is-invalid' if application.errors[:redirect_uri].present? }" %>
      <%= doorkeeper_errors_for application, :redirect_uri %>
      <span class="form-text text-secondary">
        <%= t('doorkeeper.applications.help.redirect_uri') %>
      </span>

      <% if Doorkeeper.configuration.allow_blank_redirect_uri?(application) %>
        <span class="form-text text-secondary">
          <%= t('doorkeeper.applications.help.blank_redirect_uri') %>
        </span>
      <% end %>
    </div>
  </div>

  <div class="form-group row">
    <%= f.label :confidential, class: 'col-sm-2 form-check-label font-weight-bold' %>
    <div class="col-sm-10">
      <%= f.check_box :confidential, class: "checkbox #{ 'is-invalid' if application.errors[:confidential].present? }" %>
      <%= doorkeeper_errors_for application, :confidential %>
      <span class="form-text text-secondary">
        <%= t('doorkeeper.applications.help.confidential') %>
      </span>
    </div>
  </div>

  <% known_scopes, custom_scopes = DoorkeeperScopeCatalog.split(application.scopes_string) %>
  <div class="form-group row">
    <%= f.label :scopes, class: 'col-sm-2 col-form-label font-weight-bold' %>
    <div class="col-sm-10">
      <%= f.hidden_field :scopes, id: "doorkeeper_application_scopes_value", value: application.scopes_string %>
      <%= doorkeeper_errors_for application, :scopes %>

      <style>
        .scope-picker-groups {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
          gap: 1rem;
          margin-bottom: 1rem;
        }
        .scope-picker-group {
          border: 1px solid #ced4da;
          border-radius: 0.375rem;
          padding: 0.75rem;
        }
        .scope-picker-group h4 {
          margin: 0 0 0.5rem;
          font-size: 1rem;
          font-weight: 700;
        }
        .scope-picker-item {
          margin-bottom: 0.75rem;
        }
        .scope-picker-item:last-child {
          margin-bottom: 0;
        }
        .grant-panel {
          margin-top: 0.75rem;
          padding-top: 0.5rem;
          border-top: 1px dashed #ced4da;
          font-size: 0.875rem;
        }
        .grant-panel .grant-row {
          display: flex;
          gap: 0.4rem;
          align-items: center;
          justify-content: space-between;
          margin-bottom: 0.25rem;
        }
        .grant-panel form.inline-grant-form {
          display: flex;
          gap: 0.4rem;
          flex-wrap: wrap;
          align-items: center;
          margin-top: 0.4rem;
        }
        .grant-panel select, .grant-panel input[type="number"] {
          padding: 0.2rem;
          font-size: 0.875rem;
        }
      </style>

      <%
        templates_by_type = application.persisted? ? application.resource_grant_templates.group_by(&:resource_type) : {}
        # Groups whose scopes all share one resource prefix (e.g. "organizations:read" -> "organizations")
        # get their grant controls embedded directly below the checkbox - "Admin" is excluded since its
        # blanket admin:read/write scopes aren't themselves a resource type (they narrow to *other* resources'
        # types instead, handled in the fallback section below).
      %>
      <div class="scope-picker-groups">
        <% DoorkeeperScopeCatalog.groups.each do |group| %>
          <% group_resources = group[:scopes].filter_map { |s| s[:value].split(":", 2).first if s[:value].include?(":") }.uniq %>
          <% single_resource = group_resources.first if group_resources.size == 1 && group[:name] != "Admin" %>
          <div class="scope-picker-group">
            <h4><%= group[:name] %></h4>
            <% group[:scopes].each do |scope| %>
              <div class="form-check scope-picker-item">
                <input type="checkbox" class="form-check-input scope-picker-checkbox" id="scope_<%= scope[:value].parameterize %>" data-scope="<%= scope[:value] %>" <%= "checked" if known_scopes.include?(scope[:value]) %>>
                <label class="form-check-label" for="scope_<%= scope[:value].parameterize %>">
                  <%= scope[:label] %> <code><%= scope[:value] %></code>
                </label>
                <div class="form-text text-secondary"><%= scope[:description] %></div>
              </div>
            <% end %>

            <% if single_resource && application.persisted? %>
              <div class="grant-panel">
                <strong>Restrict <code><%= single_resource %></code> to:</strong>
                <% (templates_by_type[single_resource] || []).each do |template| %>
                  <div class="grant-row">
                    <span>
                      <%= template.access_level %> &middot;
                      <% if template.scope_root_type %>
                        <%= template.scope_root_type %> #<%= template.scope_root_id %>
                      <% else %>
                        <span class="text-muted">whole type (no-op unless used as an admin grant)</span>
                      <% end %>
                    </span>
                    <%= button_to "Remove", oauth_application_resource_grant_template_path(application, template), method: :delete, class: "btn btn-sm btn-danger", form: { data: { turbo_confirm: "Remove this restriction?" } } %>
                  </div>
                <% end %>
                <%= form_with url: oauth_application_resource_grant_templates_path(application), method: :post, local: true, html: { class: "inline-grant-form" } do %>
                  <input type="hidden" name="resource_grant_template[resource_type]" value="<%= single_resource %>">
                  <select name="resource_grant_template[access_level]" class="form-control">
                    <option value="read">read</option>
                    <option value="write">write</option>
                  </select>
                  <select name="resource_grant_template[scope_root_type]" class="form-control">
                    <option value="Event">Event #</option>
                    <option value="User">User #</option>
                  </select>
                  <input type="number" name="resource_grant_template[scope_root_id]" class="form-control" placeholder="ID" style="width: 5rem;" required>
                  <button type="submit" class="btn btn-sm btn-primary">+ Add</button>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="form-group">
        <label for="doorkeeper_application_scopes_custom" class="font-weight-bold">Other scopes</label>
        <input type="text" class="form-control" id="doorkeeper_application_scopes_custom" value="<%= custom_scopes.join(' ') %>">
        <span class="form-text text-secondary">Space-separated. For scopes not listed above.</span>
      </div>

      <% if application.persisted? %>
        <% cataloged_resources = DoorkeeperScopeCatalog.groups.flat_map { |g| g[:scopes].filter_map { |s| s[:value].split(":", 2).first if s[:value].include?(":") } }.uniq %>
        <% other_templates = templates_by_type.except(*cataloged_resources) %>
        <div class="mt-4 pt-3" style="border-top: 1px solid #ced4da;">
          <label class="font-weight-bold d-block">Other resource grants</label>
          <p class="form-text text-secondary">
            For resource types without their own card above - e.g. narrowing admin access to one resource type
            (admin:read/write above stay unaffected by these; this is the alternative narrower grant), or a
            resource that doesn't have a dedicated scope yet, like <code>comments</code>.
          </p>

          <% if other_templates.any? %>
            <table class="table">
              <thead><tr><th>Resource type</th><th>Access level</th><th>Scope root</th><th></th></tr></thead>
              <tbody>
                <% other_templates.each do |resource_type, templates| %>
                  <% templates.each do |template| %>
                    <tr>
                      <td><code><%= resource_type %></code></td>
                      <td><%= template.access_level %></td>
                      <td>
                        <% if template.scope_root_type %>
                          <%= template.scope_root_type %> #<%= template.scope_root_id %>
                        <% else %>
                          <span class="text-muted">whole type</span>
                        <% end %>
                      </td>
                      <td><%= button_to "Remove", oauth_application_resource_grant_template_path(application, template), method: :delete, class: "btn btn-sm btn-danger", form: { data: { turbo_confirm: "Remove this grant?" } } %></td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          <% end %>

          <%= form_with url: oauth_application_resource_grant_templates_path(application), method: :post, local: true do |gf| %>
            <div style="display: flex; gap: 0.5rem; align-items: flex-end; flex-wrap: wrap;">
              <div>
                <label class="d-block">Resource type</label>
                <input type="text" name="resource_grant_template[resource_type]" list="known_resource_types" class="form-control" placeholder="e.g. comments" required>
                <datalist id="known_resource_types">
                  <% (cataloged_resources + ["comments"]).uniq.sort.each do |resource| %>
                    <option value="<%= resource %>">
                  <% end %>
                </datalist>
              </div>
              <div>
                <label class="d-block">Access level</label>
                <select name="resource_grant_template[access_level]" class="form-control">
                  <option value="read">read</option>
                  <option value="write">write</option>
                </select>
              </div>
              <div>
                <label class="d-block">Scope root type</label>
                <select name="resource_grant_template[scope_root_type]" class="form-control">
                  <option value="">(none - whole type)</option>
                  <option value="Event">Event (organization)</option>
                  <option value="User">User</option>
                </select>
              </div>
              <div>
                <label class="d-block">Scope root ID</label>
                <input type="number" name="resource_grant_template[scope_root_id]" class="form-control" placeholder="e.g. 42">
              </div>
              <div>
                <%= gf.submit "Add grant", class: "btn btn-primary" %>
              </div>
            </div>
            <span class="form-text text-secondary">Leave the scope root blank to grant the whole resource type (only meaningful as an admin-capability grant).</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    (function () {
      var hidden = document.getElementById("doorkeeper_application_scopes_value");
      var custom = document.getElementById("doorkeeper_application_scopes_custom");
      var checkboxes = document.querySelectorAll(".scope-picker-checkbox");

      function syncScopes() {
        var scopes = Array.prototype.filter.call(checkboxes, function (box) { return box.checked; })
          .map(function (box) { return box.dataset.scope; });
        custom.value.split(/\s+/).forEach(function (scope) {
          if (scope) scopes.push(scope);
        });
        hidden.value = Array.from(new Set(scopes)).join(" ");
      }

      checkboxes.forEach(function (box) { box.addEventListener("change", syncScopes); });
      custom.addEventListener("input", syncScopes);
      hidden.form.addEventListener("submit", syncScopes);
    })();
  </script>

  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-10">
      <%= f.submit t('doorkeeper.applications.buttons.submit'), class: 'btn btn-primary' %>
      <%= link_to t('doorkeeper.applications.buttons.cancel'), oauth_applications_path, class: 'btn btn-secondary' %>
    </div>
  </div>
<% end %>
