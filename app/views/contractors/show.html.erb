<% title "#{@contract.display_name}'s contract" %>
<% page_sm %>
<%= render "events/nav", selected: :contractors %>

<%= turbo_frame_tag "contractor_#{@contract.id}", target: "_top" do %>
  <article class="hcb-code">
    <h2 class="h2 mt0 border-none flex items-center justify-between hcb-code--heading mb-0" style="gap: 1ch">
      <span class="flex items-center py-3 gap-2 flex-grow">
        <span>
          <span class="regular muted">Contract with</span>
          <%= @contract.display_name %>
        </span>
        <span class="badge h4 bg-<%= @contract.status_color %> nowrap order-1"><%= @contract.status_text %></span>
      </span>
    </h2>

    <section class="hcb-code--info">
      <p>
        <strong>Recipient</strong>
        <%= @contract.display_name %>
      </p>
      <p>
        <strong>Email</strong>
        <%= @contract.email %>
      </p>
      <p>
        <strong>Rate</strong>
        <%= "#{render_money @contract.rate_cents}/hr" %>
      </p>
      <p>
        <strong>Period</strong>
        <%= @contract.period_label %>
      </p>
      <p>
        <strong>Purpose</strong>
        <%= @contract.description %>
      </p>
      <p>
        <strong>Total paid</strong>
        <%= render_money @contract.total_paid_cents %>
      </p>
      <% if @contract.file.attached? %>
        <p>
          <strong>Agreement</strong>
          <%= link_to "View attachment", url_for(@contract.file), data: { turbo_frame: "_top" } %>
        </p>
      <% end %>
    </section>
  </article>

  <% if @contract.status == :onboarding %>
    <%= render "application/callout", type: "info", title: "Onboarding in progress", class: "mt-4" do %>
      <%= @contract.display_name %> needs to sign their contract and complete W-9/W-8BEN tax forms before payments can be processed.
    <% end %>
  <% end %>

  <% unless @contract.status == :completed %>
    <h3 class="eyebrow muted mt-4 mb-2">Onboarding checklist</h3>
    <div class="flex flex-col gap-2">
      <% @contract.onboarding_checklist.each do |item| %>
        <div class="card flex items-center justify-between py-3 mb-0">
          <span class="flex items-center gap-2">
            <%= inline_icon item[:complete] ? "check-circle-fill" : "important-fill",
                  size: 24, class: item[:complete] ? "text-green" : "text-orange" %>
            <span class="<%= "muted" unless item[:complete] %>"><%= item[:label] %></span>
          </span>
          <span class="badge bg-<%= item[:complete] ? "success" : "warning" %>">
            <%= item[:complete] ? "Done" : "Pending" %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>

  <h3 class="mt-4 mb-2">Payments</h3>
  <% if @payments.any? %>
    <article class="table-container">
      <table>
        <thead>
          <tr>
            <th>Status</th>
            <th>Date</th>
            <th>Purpose</th>
            <th class="text-right">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr class="<%= "clickable" if organizer_signed_in? %>">
              <td>
                <span class="badge bg-<%= payment.state_color %>"><%= payment.state_text %></span>
              </td>
              <td><%= format_date payment.created_at %></td>
              <td style="max-width: 25ch;" class="overflow-hidden truncate" title="<%= payment.purpose %>">
                <%= payment.purpose %>
              </td>
              <td class="text-right">
                <%= render_money payment.amount %>
                <% if organizer_signed_in? %>
                  <%= link_to "", payment_path(payment),
                        class: "stretched-link",
                        data: popovers_enabled? ? popover_data(
                          title: "Payment of #{render_money payment.amount}",
                          src: payment_path(payment),
                          frame_id: payment.id,
                          state_url: payment_path(payment),
                          external_link: payment_path(payment)
                        ) : { turbo_frame: "_top" } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>
  <% else %>
    <%= blankslate "No payments yet" %>
  <% end %>
<% end %>
