<% if organizer_signed_in? %>
  <% is_active = params[:sort] == sort || (params[:sort].nil? && defined?(default) && default) %>
  <% current_direction = params[:direction].presence || "desc" %>
  <% next_direction = current_direction == "asc" ? "desc" : "asc" %>
  <% direction = is_active ? next_direction : "desc" %>
  <%= link_to upsert_query_params(
        sort: sort,
        direction: direction
      ),
    class: [
      "sort-button",
      ("sort-button--active" if is_active),
      ("sort-button--right" if defined?(right) && right)
    ].compact.join(" ") do %>
  <%= display || sort.humanize %>
  <%= inline_icon(current_direction == "desc" ? "down-caret" : "up-caret", size: 16) %>
<% end %>
<% else %>
  <%= display || sort.humanize %>
<% end %>
