<%= turbo_frame_tag :payee_results do %>
  <%= form_with(url: event_payees_path(event_id: @event.slug), method: :get, class: "px-4 pb-2 pt-1", data: { turbo_frame: "payee_results", controller: "form" }) do |form| %>
    <div class="input input-group max-w-none">
      <%= inline_icon "search" %>
      <%= form.text_field :q, value: params[:q], placeholder: "Search...", class: "bg-transparent", autocomplete: "off", data: { action: "input->form#submitDebounced" } %>
    </div>
  <% end %>

  <% if @payees.any? %>
    <% @payees.each do |payee| %>
      <%= link_to event_payments_new_path(event_id: @event.slug, payee_id: payee.id), class: "btn btn--list-item border-t rounded-none", data: { turbo_frame: "_top" } do %>
        <img src="<%= gravatar_url(payee.email, payee.preferred_name, payee.id, 80) %>" class="rounded-full w-10 h-10 shrink-0" alt="<%= payee.preferred_name %>">
        <div>
          <p class="font-medium"><%= payee.preferred_name %></p>
          <p class="text-sm muted"><%= payee.email %></p>
        </div>
        <% if params[:payee_id].to_s == payee.id.to_s %>
          <%= inline_icon "check-thin", class: "ml-auto success shrink-0" %>
        <% end %>
      <% end %>
    <% end %>
  <% elsif params[:q].present? %>
    <div class="px-4">
      <%= blankslate "No results for \"#{params[:q]}\"", class: "py-5 text-sm mb-2" %>
    </div>
  <% end %>
<% end %>
