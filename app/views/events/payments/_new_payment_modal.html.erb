<section class="modal modal--scroll bg-snow" data-behavior="modal" role="dialog" id="new_payment">
  <%= modal_header "Who do you want to pay?" %>

  <div class="input input-group max-w-none mb-4">
    <%= inline_icon "search" %>
    <input type="text" placeholder="Search recently paid..." class="bg-transparent" />
  </div>

  <div class="card p-0 overflow-hidden">
    <p class="text-xs bold muted uppercase tracking-wider px-4 pt-4 pb-2 m-0">Recently Paid</p>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <img src="<%= gravatar_url("gary+testing@hackclub.com", "GT", 1, 80) %>" class="rounded-full w-10 h-10 shrink-0" alt="GT" />
      <div>
        <p class="font-medium">Gary Testing</p>
        <p class="text-sm muted">gary+testing@hackclub.com</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <img src="<%= gravatar_url("sampoder@sampoder.com", "SP", 2, 80) %>" class="rounded-full w-10 h-10 shrink-0" alt="SP" />
      <div>
        <p class="font-medium">Sam Poder</p>
        <p class="text-sm muted">sampoder@sampoder.com</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <img src="<%= gravatar_url("leo@hackclub.com", "LW", 3, 80) %>" class="rounded-full w-10 h-10 shrink-0" alt="LW" />
      <div>
        <p class="font-medium">Leo Wilkin</p>
        <p class="text-sm muted">leo@hackclub.com</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <img src="<%= gravatar_url("priya@design.co", "PN", 4, 80) %>" class="rounded-full w-10 h-10 shrink-0" alt="PN" />
      <div>
        <p class="font-medium">Priya Nair</p>
        <p class="text-sm muted">priya@design.co</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <div class="w-10 h-10 shrink-0 rounded-full border-2 border-current flex items-center justify-center muted">
        <%= inline_icon "plus", size: 18 %>
      </div>
      <div>
        <p class="font-medium">New recipient</p>
        <p class="text-sm muted">Create a new payment recipient</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>

    <%= link_to event_payments_new_path(event_id: event.slug), class: "btn btn--list-item border-t rounded-none" do %>
      <div class="w-10 h-10 shrink-0 rounded-full border-2 border-current flex items-center justify-center muted">
        <%= inline_icon "edit", size: 18 %>
      </div>
      <div>
        <p class="font-medium">Enter payment details manually</p>
        <p class="text-sm muted">Enter recipient &amp; transfer details directly</p>
      </div>
      <%= inline_icon "view-forward", class: "ml-auto muted" %>
    <% end %>
  </div>
</section>
