<% title "Donations to #{@event.name}" %>
<% page_md %>
<%= render "events/nav", selected: :donations %>

<% if @donations.any? || @recurring_donations.any? || !organizer_signed_in? || params[:q].present? || params[:filter].present? %>
  <h1 class="heading gap-2 border-0 mb-2" data-controller="walkthrough" data-walkthrough-key-value="donations">
    <span class="flex items-center flex-grow">
      Donations
      <%= badge_for @donations.count, class: "bg-muted" %>
    </span>
    <% if organizer_signed_in? %>
      <div class="tooltipped tooltipped--s" style="line-height: 0;" aria-label="<%= @all_donations.not_pending.any? ? "Email all donors" : "You can't email donors when you don't have any donations!" %>">
        <%= pop_icon_to "email",
          "mailto:?bcc=#{@all_donations.pluck(:email).uniq.compact.join(',')}",
          target: "_blank",
          disabled: @all_donations.not_pending.none? %>
      </div>
    <% end %>
    <% if @event.donation_page_available? %>
      <%= render partial: "events/donations/share_page" %>
    <% end %>
  </h1>

  <% unless @event.donation_page_available? %>
    <p>You can start accepting donations once you enable it in your organization's <%= link_to "settings", edit_event_path(@event, tab: "donations") %>.</p>
  <% end %>

  <div class="statset">
    <div class="stat">
      <span class="stat__label">Total</span>
      <span class="stat__value"><%= render_money_amount @stats[:deposited] %></span>
    </div>
    <div class="stat stat--small">
      <span class="stat__label">Per month</span>
      <span class="stat__value"><%= render_money_amount @recurring_donations_monthly_sum %></span>
    </div>
  </div>

  <%= turbo_frame_tag :donations_recurring_donations_overview, src: event_recurring_donations_path(@event), loading: :eager do %>
    <%= render "application/loading_container", klass: "mt-8" %>
  <% end %>

  <h2 class="heading mt3 justify-between">
    Past donations

    <div data-controller="menu" data-menu-placement-value="bottom-end">
      <button
        type="button"
        class="btn menu__toggle overflow-visible"
        data-action="menu#toggle click@document->menu#close keydown@document->menu#keydown"
        data-menu-target="toggle">
          <%= inline_icon "download", size: 16 %>
          Export
      </button>
      <div class="menu__content menu__content--2 h5" data-menu-target="content">
        <%= link_to "Export donations (CSV)", export_donations_path(event: @event, format: :csv), target: :_blank %>
        <%= link_to "Export donations (JSON)", export_donations_path(event: @event, format: :json), target: :_blank %>
        <%= link_to "Export donors (CSV)", export_donors_donations_path(event: @event, format: :csv), target: :_blank %>
      </div>
    </div>
  </h2>

  <div class="flex items-center gap-2 flex-col-reverse sm:flex-row mb-2">
    <%= form_with(model: false, local: true, method: :get, class: "flex-1 w-full sm:w-auto") do |form| %>
      <%= render "events/filters/search", form: %>
    <% end %>
    <div class="filterbar">
      <%= link_to "Deposited", "?filter=deposited", class: "filterbar__item", "aria-selected": !["refunded"].include?(params[:filter]), role: "tab" %>
      <%= link_to "Refunded", "?filter=refunded", class: "filterbar__item", "aria-selected": params[:filter] == "refunded", role: "tab" %>
    </div>
  </div>

  <%= turbo_frame_tag :donations_donations_overview, src: event_donation_overview_path(@event), loading: :eager do %>
    <%= render "application/loading_container", klass: "mt-8" %>
  <% end %>

  <% if organizer_signed_in? %>
    <section class="modal modal--scroll bg-snow" data-behavior="modal" role="dialog" id="donation_settings">
      <%= modal_header("Settings", external_link: edit_event_path(@event, tab: "donations")) %>
      <%= turbo_frame_tag :donations_settings, src: edit_event_path(@event, tab: "donations", params: { frame: true }), loading: "lazy" do %>
        <strong>Loading...</strong>
      <% end %>
    </section>
  <% end %>
  </div>
<% else %>
  <%= render "events/one_pager",
    title: "Donations",
    support_article: "https://help.hcb.hackclub.com/en/articles/15410000-how-do-i-set-up-and-share-my-donation-page",
    screenshots: {
      light: "https://cdn.hackclub.com/019e7c92-1acf-7866-80cf-5946f5515639/image.png",
      dark: "https://cdn.hackclub.com/019e7c95-f032-727c-9379-ae4cc062889b/image.png"
    },
    hints: [
      {
        icon: "friend",
        title: "Turn supporters into funders",
        description: "Create a custom donation page in minutes. Share the link on social media, your website, or anywhere your community gathers."
      },
      {
        icon: "support",
        title: "Make giving effortless",
        description: "Donors enter their amount, pay securely, and they're done. You can suggest donation tiers or let people contribute whatever feels right."
      },
      {
        icon: "payment",
        title: "Grow sustainable funding",
        description: "Track who's supporting your work and enable recurring donations so supporters can contribute monthly."
      }
    ] do %>
    <% content_for :caption do %>
      <span class="text-sm text-muted">See <a href="https://hcb.hackclub.com/hq/donations" target="_blank" class="underline">our HQ's donations!</a></span>
    <% end %>
    <div class="flex flex-row-reverse gap-2 justify-end">
      <%= pop_icon_to "settings", edit_event_path(@event, tab: "donations") %>
      <%= render partial: "events/donations/share_page", is_blankslate: true %>
    </div>
  <% end %>
<% end %>
