<%= form_with(local: true) do |form| %>
  <div
    data-controller="transfer-form"
    data-transfer-form-ach-value="<%= new_event_ach_transfer_path(@event) %>"
    data-transfer-form-check-value="<%= new_event_increase_check_path(@event) %>"
    data-transfer-form-wire-value="<%= new_event_wire_path(@event) %>"
    data-transfer-form-wise-value="<%= new_event_wise_transfer_path(@event) %>">
    <% recent_recipients = @event.payment_recipients.limit(8) %>
    <% if recent_recipients.any? %>
    <div data-transfer-form-target="recipients">
      <div class="input input-group max-w-none h-[36px] mb2" tabindex="0">
        <%= inline_icon "search" %>
        <input type="text"
               class="bg-transparent"
               placeholder="Search recently paid..."
               data-transfer-form-target="search"
               data-action="input->transfer-form#filterRecipients"
               autocomplete="off">
      </div>

      <p class="eyebrow mb-1">Recently paid</p>
      <ul class="list list--row mb2">
        <% recent_recipients.each do |recipient| %>
          <% new_transfer_path = case recipient.payment_model
                                 when IncreaseCheck.name then new_event_increase_check_path(@event)
                                 when Wire.name then new_event_wire_path(@event)
                                 else new_event_ach_transfer_path(@event)
                                 end %>
          <%= link_to new_transfer_path,
                data: { turbo_frame: "_top", transfer_form_target: "recipient", search: "#{recipient.name} #{recipient.email}" } do %>
            <li class="gap-2">
              <%= image_tag gravatar_url(recipient.email, recipient.name.to_s, recipient.id, 64), width: 32, height: 32, class: "rounded-full shrink-none", alt: recipient.name %>
              <p class="min-w-0">
                <strong class="block truncate"><%= recipient.name %></strong>
                <span class="muted block truncate"><%= recipient.email %></span>
              </p>
            </li>
          <% end %>
        <% end %>
      </ul>
      <p class="muted text-center" data-transfer-form-target="noResults" hidden>No recipients match your search.</p>

      <ul class="list list--row">
        <a href="javascript:void(0)" data-action="click->transfer-form#showManual">
          <li class="gap-2">
            <span class="flex items-center justify-center bg-muted rounded-full" style="width: 32px; height: 32px;">
              <%= inline_icon "payment-transfer", size: 20 %>
            </span>
            <p>
              <strong class="block">Send manually</strong>
              <span class="muted block">Enter recipient &amp; transfer details directly</span>
            </p>
          </li>
        </a>
      </ul>
    </div>
    <% end %>
    <div data-transfer-form-target="home" <%= "hidden" if recent_recipients.any? %>>
      <fieldset>
        <% if recent_recipients.any? %>
          <a class="no-underline text-xs inline-flex items-center -ml-2" href="javascript:void(0)" data-action="click->transfer-form#showRecipients">
            <%= inline_icon "view-back" %>
            Back
          </a>
        <% end %>
        <legend class="heading h2 pb2">What type of transfer?</legend>
        <div class="field field--options fit">
          <%= link_to new_event_ach_transfer_path(@event), class: "text-decoration-none btn--form-option", data: { turbo_frame: "_top" } do %>
            <%= inline_icon "payment-transfer", size: 28 %>
            <strong>ACH transfer</strong>
            <small>United States</small>
          <% end %>
          <%= link_to new_event_increase_check_path(@event), class: "text-decoration-none btn--form-option", data: { turbo_frame: "_top" } do %>
            <%= inline_icon "email", size: 28 %>
            <strong>Mailed check</strong>
            <small>United States</small>
          <% end %>
          <%= link_to new_event_wise_transfer_path(@event), class: "text-decoration-none btn--form-option relative overflow-hidden", data: { turbo_frame: "_top" }, disabled: true do %>
            <%= inline_icon "wise", size: 28 %>
            <strong>Wise transfer</strong>
            <small>International</small>
          <% end %>
          <%= link_to new_event_wire_path(@event), class: "text-decoration-none btn--form-option relative overflow-hidden", data: { turbo_frame: "_top" } do %>
            <%= inline_icon "web", size: 28 %>
            <div class="badge badge--corner bg-info m1 mt0" style="width: fit-content;">$500 minimum</div>
            <strong>Wire transfer</strong>
            <small>International</small>
          <% end %>
          <%= link_to new_disbursement_path(source_event_id: @event), class: "text-decoration-none btn--form-option", data: { turbo_frame: "_top" } do %>
            <%= inline_icon "bank-account", size: 28 %>
            <strong>HCB transfer</strong>
            <small>Any HCB organization</small>
          <% end %>
          <% if @event.plan.card_grants_enabled? %>
            <%= link_to new_event_card_grant_path(@event), class: "text-decoration-none btn--form-option", data: { turbo_frame: "_top", behavior: "modal_trigger", modal: "create_card_grant" } do %>
              <%= inline_icon "card", size: 28 %>
              <strong>Card grant</strong>
              <small>A grant sent through HCB</small>
            <% end %>
          <% end %>
        </div>
      </fieldset>
      <a class="w-full text-center block no-underline -mb-2" href="javascript:void(0)" data-action="click->transfer-form#showWizard">Which method should I use? <strong>Help me decide &rarr;</strong></a>
    </div>
    <div data-transfer-form-target="wizard" hidden>
      <a class="no-underline text-xs inline-flex items-center -ml-2" href="javascript:void(0)" data-action="click->transfer-form#hideWizard">
        <%= inline_icon "view-back" %>
        Exit
      </a>
      <p class="eyebrow mb-0">Help me decide</p>
      <h3 class="mt-2 font-bold mb-4" data-transfer-form-target="question"></h3>
      <div class="flex gap-2">
        <button type="button" class="btn shadow-none" data-transfer-form-target="yes" data-action="click->transfer-form#yesClickHandler">
          Yes
          <%= inline_icon "check-thin", style: "margin-right: -5px;margin-left: 5px" %>
        </button>
        <button type="button" class="btn shadow-none" data-transfer-form-target="no" data-action="click->transfer-form#noClickHandler">
          No
          <%= inline_icon "view-close", style: "margin-right: -5px;margin-left: 5px" %>
        </button>
      </div>
    </div>
    <div data-transfer-form-target="answer" hidden>
      <a class="no-underline text-xs inline-flex items-center -ml-2" href="javascript:void(0)" data-action="click->transfer-form#hideWizard">
        <%= inline_icon "view-back" %>
        Exit
      </a>
      <p class="eyebrow pt-0 mb-0">Our recommendation</p>
      <h3 class="mt-2 font-bold mb-2 capitalize" data-transfer-form-target="answerText"></h3>
      <div style="font-weight: normal" class="mb-4" data-transfer-form-target="wiseAnswerNote">
        <strong>Note:</strong>
        Wise does <strong>not</strong> support these currencies:
        <ul>
          <% WiseTransfer.unsupported_currencies_supported_by_wire.excluding("USD").each do |currency_code| %>
            <li><%= currency_code %></li>
          <% end %>
        </ul>
        If you need to send to one of these currencies, <strong>please select "International wire" instead.</strong>
      </div>
      <a href="#" data-transfer-form-target="learnMore" class="mb-3 inline-block no-underline" target="_blank">Learn more &rarr;</a>
      <div class="flex gap-2">
        <button type="button" class="btn bg-primary shadow-none" data-transfer-form-target="answerCTA" data-action="click->transfer-form#showAnswer">
          Let's do it!
          <%= inline_icon "view-forward", style: "margin-right: -5px;margin-left: 5px" %>
        </button>
        <button type="button" class="btn bg-muted shadow-none" data-action="click->transfer-form#reset">
          Reset
          <%= inline_icon "view-reload", style: "margin-right: -5px;margin-left: 5px" %>
        </button>
      </div>
      <div>
      </div>
    <% end %>
