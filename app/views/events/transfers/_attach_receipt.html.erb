<div class="md:flex items-center justify-between gap-4">
  <div class="flex-1">
    <div class="flex items-start justify-between gap-2">
      <div>
        <%= form.label :file, "Attach a receipt / invoice", class: "font-semibold" %>
        <span class="muted">Required for reimbursements / goods & services payments.</span>
      </div>

      <%= link_to "https://help.hcb.hackclub.com/en/articles/15410229-what-counts-as-a-valid-receipt-and-when-is-it-due",
          class: "inline-flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border border-muted/60 bg-white text-muted shadow-sm tooltipped tooltipped--s hover:bg-slate-50",
          target: "_blank",
          rel: "noopener noreferrer",
          "aria-label" => "What counts as a valid receipt?" do %>
        <%= inline_icon "question-mark", size: 14 %>
      <% end %>
    </div>
  </div>

  <div
    data-controller="file-upload file-drop form"
    data-action="dragover@window->file-drop#dragover drop@window->file-drop#drop dragenter@window->file-drop#dragenter dragleave@window->file-drop#dragleave">
    <%= form.file_field :file,
        multiple: true,
        include_hidden: false,
        required: false,
        accept: "image/*,image/heic,.pdf",
        data: {
          "file-drop-target"   => "fileInput",
          "file-upload-target" => "input"
        },
        disabled: %>
    <button data-file-upload-target="preview" type="button"></button>
    <div data-file-upload-target="clear"></div>
  </div>
</div>
