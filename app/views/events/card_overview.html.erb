<% title "Cards for #{@event.name}" %>
<% page_md %>
<%= render "events/nav", selected: :cards %>
<% @show_card_popovers = Flipper.enabled?(:hcb_code_popovers_2023_06_16, current_user) && organizer_signed_in? && !@event.demo_mode %>
<% if @event.stripe_cards.any? || !organizer_signed_in? || @has_filter %>
  <% if current_user.try(:full_name).try(:blank?) %>
    <h1 class="heading">
      <span class="flex items-center">
        Cards
      </span>
    </h1>

    <%= render "cards/name_required" %>
  <% else %>
    <h1 class="heading flex-col sm:flex-row mb-0 border-0 gap-2 mt-3">
      <span class="flex-grow flex items-center flex-1">
        Cards
        <%= badge_for @event.stripe_cards.active.on_main_ledger.count, class: "bg-muted" %>
      </span>

      <div class="flex items-center gap-2">
        <%= pop_icon_to(@view == "list" ? "grid" : "list", upsert_query_params(view: @view == "list" ? "grid" : "list")) %>
        <% if organizer_signed_in?(as: :member) %>
          <%= link_to event_cards_new_path(event_id: @event.slug), class: "btn bg-success", data: { behavior: "modal_trigger", modal: "order_card" } do %>
            <%= inline_icon "card-add" %>
            Order a card
          <% end %>
        <% end %>
      </div>
    </h1>

    <div class="flex items-center gap-2 mt-2">
      <%= form_with(model: false, local: true, method: :get, class: "flex-1") do |form| %>
        <%= hidden_field_tag :status, @status if @status %>
        <%= hidden_field_tag :type, @type if @type %>
        <%= hidden_field_tag :user, params[:user] if params[:user] %>
        <%= render "events/filters/search", form: %>
      <% end %>
      <%= render "events/filters/menu", filters: @filter_options unless @has_filter %>

    </div>
    <%= render "events/filters/bar", filters: @filter_options if @has_filter %>

    <% if control = @organizer_position&.active_spending_control %>
      <% title = control.balance_cents.zero? ? "You are not authorized to spend any money at the moment." : "You currently have a spending limit of #{render_money control.balance_cents}" %>
      <%= render "application/callout", type: control.balance_cents.zero? ? "warning" : "info", title: do %>
        <ul class="m0">
          <li>Spending controls are enabled for this organization.</li>
          <li>Since you're a <%= @organizer_position.role %>, you must request allowances to spend money.</li>
          <li>Managers can issue allowances
            from <%= link_to "your spending controls page", event_organizer_position_spending_controls_path(organizer_position_id: @organizer_position) %>
            , which can be accessed from the <%= link_to "team page", event_team_path(@event) %>.
          </li>
        </ul>
      <% end %>
    <% end %>

    <% if @view == "list" %>
      <%= render "event_cards_table", stripe_cards: @paginated_stripe_cards, status: @status %>
      <%= paginate @paginated_stripe_cards %>
    <% elsif @cards_by_user %>
      <% preview_count = 3 %>
      <% if @cards_by_user.any? %>
        <% @cards_by_user.each do |user, cards| %>
          <section class="mt-3">
            <div class="flex items-center gap-2">
              <%= link_to upsert_query_params(user: user.slug, page: nil), class: "flex items-center gap-2 text-decoration-none text-inherit flex-1 min-w-0" do %>
                <%= user_mention user %>
                <%= badge_for cards.count, class: "bg-muted flex-shrink-0 mx-0" %>
                <div class="menu__divider flex-1 ml-2"></div>
              <% end %>
            </div>
            <article class="mixed-grid grid--spacious">
              <%= render partial: "stripe_cards/stripe_card", collection: cards.first(preview_count), locals: { headless: true } %>
            </article>
            <% if cards.count > preview_count %>
              <div class="flex">
                <%= link_to upsert_query_params(user: user.slug, page: nil), class: "btn ml-auto" do %>
                  +<%= cards.count - preview_count %> more
                <% end %>
              </div>
            <% end %>
          </section>
        <% end %>
        <%= paginate @paginated_user_groups %>
      <% else %>
        <% if organizer_signed_in? %>
          <%= blankslate "You don’t have any #{@status} cards yet" %>
        <% else %>
          <%= blankslate "This organization doesn’t have any #{@status} cards" %>
        <% end %>
      <% end %>
    <% else %>
      <article class="mixed-grid grid--spacious">
        <%= render partial: "stripe_cards/stripe_card", collection: @paginated_stripe_cards %>
      </article>

      <% if @paginated_stripe_cards.blank? %>
        <% if organizer_signed_in? %>
          <%= blankslate "You don’t have any #{@status} cards yet" %>
        <% else %>
          <%= blankslate "This organization doesn’t have any #{@status} cards" %>
        <% end %>
      <% end %>

      <%= paginate @paginated_stripe_cards %>
    <% end %>

    <% if organizer_signed_in? || @event.used_emburse? %>
      <section class="grid mt3">
        <% if organizer_signed_in? %>
          <div class="text-center">
            <%= link_to my_cards_path, class: "btn bg-accent" do %>
              All your cards →
            <% end %>
            <% if @event.used_emburse? %>
              <%= link_to event_emburse_cards_overview_path(event_id: @event.slug), class: "mt-3 block no-underline" do %>
                See previous Emburse cards
              <% end %>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  <% end %>
<% else %>
 <%= render "events/one_pager",
    title: "Cards",
    support_article: "https://help.hcb.hackclub.com/en/articles/13356182-how-do-i-spend-my-money-on-hcb-and-use-hcb-cards",
    screenshots: {
      light: "https://cdn.hackclub.com/019eb7bb-a291-7fe9-a78f-4656eaa80629/file-cb800d0bbd987c998a23ae387d7ebaa4.png",
      dark: "https://cdn.hackclub.com/019eb7bb-a001-7bde-a802-612f6c523c69/image.png",
    },
    hints: [
      {
        icon: "card",
        title: "Order physical and virtual cards",
        description: "Easily order physical and virtual cards for your organization to streamline spending and manage expenses."
      },
      {
        icon: "view",
        title: "Control spending with ease",
        description: "Set spending limits and monitor transactions in real-time to ensure responsible use of funds."
      },
      {
        icon: "docs",
        title: "Simplify expense tracking",
        description: "Automatically categorize and track expenses, making budgeting and financial reporting a breeze."
      }
    ] do %>
    <% content_for :caption do %>
      <span class="text-sm text-muted">See <a href="https://hcb.hackclub.com/hq/cards" target="_blank" class="underline">how we utilize cards on HQ!</a></span>
    <% end %>
    <% if organizer_signed_in?(as: :member) %>
      <%= link_to event_cards_new_path(event_id: @event.slug), class: "btn bg-success", data: { behavior: "modal_trigger", modal: "order_card" } do %>
        <%= inline_icon "card-add" %>
        Order a card
      <% end %>
    <% end %>

  <% end %>
<% end %>

<% if organizer_signed_in? %>
  <section class="modal modal--scroll bg-snow" data-behavior="modal" role="dialog" id="order_card">
    <%= modal_header "Order a card" %>
    <%= render "stripe_cards/form", stripe_card: StripeCard.new %>
  </section>
<% end %>
