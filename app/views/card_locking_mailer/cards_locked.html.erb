<p>
Your HCB cards have been locked because <%= @hcb_codes.count %> <%= "settled charge".pluralize(@hcb_codes.count) %> still <%= @hcb_codes.count == 1 ? "is" : "are" %> missing <%= "receipt".pluralize(@hcb_codes.count) %> more than 72 hours later.
</p>

<p>
Every receipt must be uploaded within 72 hours of the charge settling. You can manage your receipts on the HCB <%= link_to "receipts page", my_inbox_url %>.
</p>

<h3>Receipts violating the 72-hour rule (<%= @hcb_codes.count %>)</h3>
<%= render "transactions_table", hcb_codes: @hcb_codes, show_org: @show_org %>

<% if @hcb_codes_upcoming.any? %>
  <h3>Missing receipts still within 72 hours</h3>
  <%= render "transactions_table", hcb_codes: @hcb_codes_upcoming, show_org: @show_org %>
<% end %>
